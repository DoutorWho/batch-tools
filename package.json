{
  "name": "batch-tools",
  "displayName": "Batch Tools",
  "description": "Ferramenta de autocomplete para Batch (.bat)",
  "version": "0.1.3",
  "publisher": "DoutorWho",

  "categories": [
    "Programming Languages",
    "Other"
  ],

  "keywords": [
    "batch",
    "cmd",
    "autocomplete",
    "vscode-extension",
    "windows"
  ],

  "license": "MIT",

  "icon": "images/icon.png",

  "engines": {
    "vscode": "^1.80.0"
  },

  "activationEvents": [
    "onLanguage:bat"
  ],

  "main": "./extension.js",

  "repository": {
    "type": "git",
    "url": "https://github.com/DoutorWho/batch-tools"
  },

  "homepage": "https://github.com/DoutorWho/batch-tools",

  "bugs": {
    "url": "https://github.com/DoutorWho/batch-tools/issues"
  },

  "contributes": {
    "grammars": [
      {
        "scopeName": "batch.variable.injection",
        "path": "./syntaxes/batch.injection.json",
        "injectTo": [
          "source.batchfile"
        ]
      }
    ]
  }
}